generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum user_role {
  SYSTEM_OWNER
  BUSINESS_OWNER
}

model users {
  id       String @id @default(uuid())
  email    String @unique
  password String

  first_name String
  last_name  String
  avatar     String?
  gender     String?
  country    String?
  phone      String?

  role        user_role   @default(BUSINESS_OWNER)
  is_verified Boolean     @default(false)
}
