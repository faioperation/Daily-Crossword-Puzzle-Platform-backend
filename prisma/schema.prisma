generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===============================
// ENUMS
// ===============================

enum UserRole {
  SYSTEM_OWNER
  USER
}

enum PuzzleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PuzzleDifficulty {
  EASY
  MEDIUM
  HARD
}

enum ClueDirection {
  ACROSS
  DOWN
}

enum WinnerStatus {
  PENDING
  ANNOUNCED
  CLAIMED
}

// ===============================
// USER
// ===============================

model User {
  id String @id @default(uuid())

  name     String
  username String? @unique
  email    String  @unique
  password String

  avatar String?

  role UserRole @default(USER)

  isActive   Boolean @default(true)
  isVerified Boolean @default(false)

  lastLoginAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  createdPuzzles Puzzle[]        @relation("PuzzleCreatedBy")
  // attempts       PuzzleAttempt[]
  // winners        PuzzleWinner[]
  // statistic      UserStatistic?

  // testerDevices  TesterDevice[]  @relation("TesterCreatedBy")
  // blockedDevices BlockedDevice[] @relation("BlockedBy")

  // announcements Announcement[]

  @@map("users")
}

// ===============================
// PUZZLE
// ===============================

model Puzzle {
  id String @id @default(uuid())

  title       String
  description String?

  rows    Int
  columns Int

  rules String?

  difficulty PuzzleDifficulty

  status PuzzleStatus @default(DRAFT)

  publishDate DateTime?

  dailyPrize String?

  winnerSelected   Boolean   @default(false)
  winnerSelectedAt DateTime?

  createdById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  createdBy User        @relation("PuzzleCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  cells     PuzzleCell[]

  @@index([status])
  @@index([publishDate])
  @@index([difficulty])
  @@map("puzzles")
}

// ===============================
// PUZZLE CELL
// ===============================

model PuzzleCell {
  id String @id @default(uuid())

  puzzleId String
  puzzle   Puzzle @relation(fields: [puzzleId], references: [id], onDelete: Cascade)

  row    Int
  column Int

  letter  String?
  isBlack Boolean @default(false)

  number Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([puzzleId, row, column])
  @@index([puzzleId])
  @@map("puzzle_cells")
}

